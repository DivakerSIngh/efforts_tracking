# SQL Server connection string
# Windows Authentication (LocalDB / domain account):
#   DRIVER={ODBC Driver 17 for SQL Server};SERVER=(localdb)\MSSQLLocalDB;DATABASE=Efforts_Tracking;Trusted_Connection=yes;
# SQL Authentication (production / Azure SQL):
#   DRIVER={ODBC Driver 17 for SQL Server};SERVER=yourserver.database.windows.net;DATABASE=Efforts_Tracking;UID=user;PWD=YourPassword
DB_CONNECTION_STRING=DRIVER={ODBC Driver 17 for SQL Server};SERVER=(localdb)\MSSQLLocalDB;DATABASE=Efforts_Tracking;Trusted_Connection=yes;

# JWT configuration
JWT_SECRET_KEY=replace-with-a-long-random-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=480

# CORS — Angular dev server origin
ALLOWED_ORIGINS=["http://localhost:4200"]

# SMTP email settings (Phase 8)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@efforttracker.com
APP_URL=http://localhost:4200
